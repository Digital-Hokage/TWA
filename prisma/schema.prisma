generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Donation {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  amount     Int
  pan        String?
  message    String?
  status     String   @default("pending")
  razorpayId String?
  createdAt  DateTime @default(now())
}

model Volunteer {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  availability String?
  message      String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model MediaArticle {
  id          String   @id @default(cuid())
  publication String
  date        String
  year        Int      @default(0)
  headline    String
  excerpt     String?
  relevance   String?
  url         String?
  byDrRevathi Boolean  @default(false)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model SiteStat {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Partner {
  id          String  @id @default(cuid())
  name        String
  type        String
  description String
  initials    String
  logoPath    String?
  sortOrder   Int     @default(0)
  visible     Boolean @default(true)
}

model FAQ {
  id        String  @id @default(cuid())
  question  String
  answer    String
  sortOrder Int     @default(0)
  visible   Boolean @default(true)
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())
}
