# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
# This site is a STATIC EXPORT (output: 'export') for shared/FTP hosting.
# Only NEXT_PUBLIC_* variables are used — they are baked into the static build.
# The old server-side variables (ADMIN_PASSWORD_HASH, JWT_SECRET, DATABASE_URL,
# RAZORPAY_KEY_SECRET) are only needed if you restore the backend from _disabled/
# on a Node-capable host.

# ── Forms (Web3Forms) ──────────────────────────────────────────
# Get a free Access Key from web3forms.com — free, no backend needed.
# Contact / Volunteer / Donate-pledge submissions are emailed to your inbox.
NEXT_PUBLIC_WEB3FORMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Google Analytics 4 (get from analytics.google.com) ─────────
# Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Razorpay hosted Payment Page (optional) ────────────────────
# Static hosting can't run server-side Razorpay verification. Instead, create a
# hosted Payment Page/Button in the Razorpay Dashboard (Payment Pages) and paste
# its public URL here. If left blank, the donate form shows the pledge-only flow.
NEXT_PUBLIC_RAZORPAY_PAYMENT_URL=

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND ONLY — not used by the static build. Needed only if you restore the
# admin CMS + database + server-side payments from _disabled/ on a Node host.
# ─────────────────────────────────────────────────────────────────────────────
# ADMIN_PASSWORD_HASH=bcrypt_hash_here
# JWT_SECRET=64_byte_hex_here
# DATABASE_URL="mysql://user:pass@host:3306/dbname"
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
