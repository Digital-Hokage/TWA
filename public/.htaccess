# TWA Chennai — twachennai.org
# Apache/LiteSpeed .htaccess for the Next.js static export.
# This file lives in /public, is copied into /out during `next build`,
# and is uploaded to the web root (public_html) by the deploy workflow.

Options -Indexes
RewriteEngine On

# ── Force HTTPS ───────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Force www → non-www ───────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.twachennai\.org [NC]
RewriteRule ^(.*)$ https://twachennai.org/$1 [L,R=301]

# ── Clean URLs for the static export ──────────────────────────
# With trailingSlash: true, every route is emitted as <route>/index.html.
# If the request is not an existing file/dir, serve its index.html.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# ── Custom error page ─────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Long-lived caching for fingerprinted static assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # HTML must always be revalidated so content updates go live immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
