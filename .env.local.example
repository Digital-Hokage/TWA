# Copy this file to .env.local and fill in real values before deploying.
# NEVER commit .env.local to git — it contains secrets.

# Admin portal credentials
# Set a strong password (min 12 chars, mix of letters, numbers, symbols)
ADMIN_PASSWORD=Password123!

# A random secret string used for the session cookie value.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=ab95d00c8f366480fc3e6ca8dcd877eb0a18810146e4120f7e0b8df998c55f6d

# Google Analytics 4 (optional — add when GA4 property is created)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
